# ==================================================
# RumahOTP — Environment Variables
# ==================================================
# Copy file ini menjadi .env.local dan isi nilainya
# cp .env.example .env.local

# --------------------------------------------------
# DATABASE (Supabase PostgreSQL)
# --------------------------------------------------
# Connection string untuk Prisma (connection pooling via pgBouncer)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection untuk Prisma Migrate (tanpa pgBouncer)
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

# --------------------------------------------------
# NEXTAUTH (Authentication)
# --------------------------------------------------
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-here-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# --------------------------------------------------
# RUMAHOTP API
# --------------------------------------------------
# API Key dari dashboard RumahOTP (rumahotp.io)
RUMAHOTP_API_KEY="your-rumahotp-api-key-here"

# --------------------------------------------------
# PAKASIR PAYMENT GATEWAY
# --------------------------------------------------
# Project identifier dari dashboard Pakasir
PAKASIR_PROJECT="your-pakasir-project-id"
# API Key Pakasir
PAKASIR_API_KEY="your-pakasir-api-key"
# URL callback setelah pembayaran (URL publik aplikasi ini)
PAKASIR_CALLBACK_URL="https://yourdomain.com/api/webhooks/pakasir"
PAKASIR_RETURN_URL="https://yourdomain.com/deposit?status=success"

# --------------------------------------------------
# TELEGRAM NOTIFICATION BOT
# --------------------------------------------------
# Token bot dari @BotFather di Telegram
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
# Chat ID / Group ID yang menerima notifikasi
TELEGRAM_CHAT_ID="your-telegram-chat-id"

# --------------------------------------------------
# APP CONFIG
# --------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="RumahOTP"
