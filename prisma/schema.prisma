// Prisma schema — NOKOSKU Platform
// PostgreSQL (Supabase) — Production

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String        @id @default(uuid())
  email          String        @unique
  password       String        @default("")
  name           String?
  googleId       String?       @unique @map("google_id")
  balance        Float         @default(0)
  role           String        @default("USER")
  referralCode   String?       @unique @map("referral_code")
  referredBy     String?       @map("referred_by")
  isBlocked      Boolean       @default(false) @map("is_blocked")
  telegramChatId String?       @map("telegram_chat_id")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  transactions   Transaction[]
  orders         Order[]
  bandingHistory BandingHistory[]

  @@map("users")
}

model Transaction {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  amount           Float
  status           String   @default("PENDING")
  type             String
  gatewayReference String?  @map("gateway_reference")
  paymentMethod    String?  @map("payment_method")
  paymentUrl       String?  @map("payment_url")
  note             String?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

model Order {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  providerOrderId String?   @map("provider_order_id")
  targetData      String    @map("target_data")
  serviceCategory String    @map("service_category")
  productName     String    @map("product_name")
  status          String    @default("PENDING")
  cost            Float
  baseCost        Float     @map("base_cost")
  resultData      String?   @map("result_data")
  expiresAt       DateTime? @map("expires_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("orders")
}

model Setting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

model AppConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String   @db.Text
  label     String?
  group     String   @default("general")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_configs")
}

// ─── OtpService: layanan pilihan cepat OTP yang dikelola Admin ──────────────────────
model OtpService {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique  // Kode layanan Hero-SMS (contoh: "wa", "mnt")
  emoji     String   @default("📱")
  isHot     Boolean  @default(false) @map("is_hot")
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("otp_services")
}

// ─── PaymentMethod: metode deposit dinamis dikelola via Admin Panel ───────────
model PaymentMethod {
  id               String   @id @default(uuid())
  name             String
  code             String   @unique
  category         String   @default("indonesia") // "indonesia" | "crypto"
  adminFeePercent  Float    @default(0.7) @map("admin_fee_percent")
  instruction      String?  @db.Text
  iconUrl          String?  @map("icon_url")
  estimasiMenit    Int      @default(5) @map("estimasi_menit")
  isActive         Boolean  @default(true) @map("is_active")
  sortOrder        Int      @default(0) @map("sort_order")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("payment_methods")
}

// ─── SmtpAccount: rotasi pengirim email untuk fitur Banding ──────────────────
model SmtpAccount {
  id           String   @id @default(uuid())
  email        String   @unique
  appPassword  String   @map("app_password")
  host         String   @default("smtp.gmail.com")
  port         Int      @default(587)
  isActive     Boolean  @default(true) @map("is_active")
  usageCount   Int      @default(0) @map("usage_count")
  dailyLimit   Int      @default(100) @map("daily_limit")
  lastUsedAt   DateTime? @map("last_used_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  bandingHistory BandingHistory[]

  @@map("smtp_accounts")
}

// ─── BandingHistory: riwayat penggunaan fitur Banding WhatsApp ───────────────
model BandingHistory {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  targetNumber String   @map("target_number")
  smtpId       String?  @map("smtp_id")
  smtpEmail    String?  @map("smtp_email")
  status       String   @default("PENDING") // PENDING | SUCCESS | FAILED
  errorMessage String?  @map("error_message") @db.Text
  cost         Float    @default(500)
  createdAt    DateTime @default(now()) @map("created_at")

  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  smtp   SmtpAccount? @relation(fields: [smtpId], references: [id], onDelete: SetNull)

  @@map("banding_history")
}
