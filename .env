# NOKOSKU — Environment Variables

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="file:./dev.db"

# ─── Next Auth ───────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="nokosku-super-secret-jwt-key-2024-change-in-prod"

# ─── Google OAuth (isi dari Google Cloud Console) ────────────────────────────
# Buat di: https://console.cloud.google.com → APIs → Credentials → OAuth 2.0
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID="GOOGLE_CLIENT_ID_DISINI"
GOOGLE_CLIENT_SECRET="GOOGLE_CLIENT_SECRET_DISINI"

# ─── RumahOTP API ────────────────────────────────────────────────────────────
# Dapatkan di: https://www.rumahotp.io/developer/api
# Set ke "MOCK" untuk mode pengembangan lokal
RUMAHOTP_API_KEY="rk-dev-rOwiCEzqVcEaspywTqXHqirtWqDNyhqo"

# ─── Pakasir Payment Gateway ─────────────────────────────────────────────────
# Dapatkan di: https://pakasir.com atau hubungi provider
PAKASIR_API_KEY="MOCK"

# ─── Telegram Bot ────────────────────────────────────────────────────────────
# Buat bot di: https://t.me/BotFather
# Chat ID bisa grup admin ("-100xxxxxxxxx") atau chat pribadi
TELEGRAM_BOT_TOKEN="MOCK"
TELEGRAM_CHAT_ID="MOCK"
